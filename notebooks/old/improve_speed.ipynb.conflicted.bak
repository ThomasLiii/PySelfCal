   "source": [
    "# %% Scaling Benchmark: compare real workload vs synthetic baselines\n",
    "# If setup_lsqr's curve matches mem_bandwidth → memory-BW limited\n",
    "# If it matches compute → compute limited (turbo/thermal throttling)\n",
    "# If it's worse than both → IPC/serialization or allocation contention\n",
    "\n",
    "from concurrent.futures import ProcessPoolExecutor\n",
    "from SelfCal import MakeMap\n",
    "\n",
    "SUBSET = 100          # reproj files for real workload\n",
    "N_SYNTH = 32          # tasks for synthetic workloads\n",
    "WORKERS = [1, 2, 4, 8, 16, 32]\n",
    "\n",
    "reproj_subset = cc.reproj_list[:SUBSET]\n",
    "\n",
    "# --- Synthetic baselines (import numpy inside for fork safety) ---\n",
    "def _mem_bw_task(_):\n",
    "    \"\"\"Memory-bandwidth bound: streaming ops on large arrays (~40 MB each).\"\"\"\n",
    "    import numpy as _np\n",
    "    a = _np.random.rand(5_000_000)\n",
    "    b = _np.random.rand(5_000_000)\n",
    "    for _ in range(100):\n",
    "        c = a + b; a = c * 0.5; b = a + c\n",
    "    return 0\n",
    "\n",
    "def _compute_task(_):\n",
    "    \"\"\"Compute-bound: trig on small array that fits in L2 cache (32 KB).\"\"\"\n",
    "    import numpy as _np\n",
    "    a = _np.random.rand(4096)\n",
    "    for _ in range(25_000):\n",
    "        a = _np.sin(a); a = _np.cos(a)\n",
    "    return 0\n",
    "\n",
    "# --- Run ---\n",
    "results = {'setup_lsqr': {}, 'mem_bandwidth': {}, 'compute': {}}\n",
    "\n",
    "for nw in WORKERS:\n",
    "    gc.collect()\n",
    "\n",
    "    # Real workload\n",
    "    t0 = time.time()\n",
    "    MakeMap.setup_lsqr(\n",
    "        reproj_subset, cc.ref_shape,\n",
    "        chunk_map=det_chunk_map,\n",
    "        grid_valid_weight=det_valid_mask_padded,\n",
    "        apply_mask=True, apply_weight=False,\n",
    "        outlier_thresh=5.0, max_workers=nw, batch_size=2,\n",
    "        offset_regularization=True, reg_weight=0.1,\n",
    "        adj_info=adj_info, weighted_damping=True, damp_weight=0.1,\n",
    "    )\n",
    "    results['setup_lsqr'][nw] = time.time() - t0\n",
    "\n",
    "    # Memory-bandwidth bound\n",
    "    t0 = time.time()\n",
    "    with ProcessPoolExecutor(max_workers=nw) as ex:\n",
    "        list(ex.map(_mem_bw_task, range(N_SYNTH)))\n",
    "    results['mem_bandwidth'][nw] = time.time() - t0\n",
    "\n",
    "    # Compute bound\n",
    "    t0 = time.time()\n",
    "    with ProcessPoolExecutor(max_workers=nw) as ex:\n",
    "        list(ex.map(_compute_task, range(N_SYNTH)))\n",
    "    results['compute'][nw] = time.time() - t0\n",
    "\n",
    "    print(f\"workers={nw:3d}  lsqr={results['setup_lsqr'][nw]:6.1f}s  \"\n",
    "          f\"membw={results['mem_bandwidth'][nw]:5.1f}s  \"\n",
    "          f\"compute={results['compute'][nw]:5.1f}s\")"
   ]
  },
  {
