   "source": [
    "# %% Plot scaling results\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(13, 5))\n",
    "ws = sorted(WORKERS)\n",
    "\n",
    "for label, times in results.items():\n",
    "    t_ref = times[ws[0]]\n",
    "    speedup = [t_ref / times[w] for w in ws]\n",
    "    efficiency = [s / (w / ws[0]) for s, w in zip(speedup, ws)]\n",
    "    ax1.plot(ws, speedup, 'o-', label=label, lw=2)\n",
    "    ax2.plot(ws, efficiency, 'o-', label=label, lw=2)\n",
    "\n",
    "ax1.plot(ws, [w / ws[0] for w in ws], 'k--', alpha=0.3, label='ideal linear')\n",
    "ax1.set(xlabel='Workers', ylabel=f'Speedup (relative to {ws[0]} worker)')\n",
    "ax1.set_title('Scaling')\n",
    "ax1.legend()\n",
    "ax1.grid(True, alpha=0.3)\n",
    "\n",
    "ax2.axhline(1.0, color='k', ls='--', alpha=0.3, label='ideal')\n",
    "ax2.set(xlabel='Workers', ylabel='Parallel Efficiency')\n",
    "ax2.set_title('Efficiency')\n",
    "ax2.set_ylim(0, 1.2)\n",
    "ax2.legend()\n",
    "ax2.grid(True, alpha=0.3)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
